MONGO_URI=your-mongodb-connection-string

# Resend (https://resend.com) — used to send the contact form notification email.
# Get this from your Resend dashboard → API Keys.
RESEND_API_KEY=your-resend-api-key

# The email address that receives contact form notifications (your own inbox).
EMAIL_USER=your-gmail-or-any-email-address

PORT=5000

# Comma-separated list of frontend URLs allowed to call this API.
# Update this every time your Vercel URL changes.
ALLOWED_ORIGINS=http://localhost:5173,https://your-actual-vercel-url.vercel.app